# Microsoft Foundry
# For local dev, set these manually. For hosted agents, FOUNDRY_PROJECT_ENDPOINT
# is auto-injected by the Foundry platform.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-4.1-mini

# Agent Mode: "local-direct" (recommended for local dev), "local" (run in-process), "hosted" (proxy to Foundry hosted agent), or "containerapp" (proxy to self-hosted agent service)
AGENT_MODE=local-direct

# Local-direct mode (dev-only): bypass Foundry Toolbox and call local services directly.
# Set AGENT_MODE=local-direct to use these URLs.
INVENTORY_MCP_URL=http://localhost:8001
WORK_ORDERS_API_URL=http://localhost:8002

# Hosted mode settings (when AGENT_MODE=hosted)
HOSTED_AGENT_NAME=fibey-agent

# Container App mode settings (when AGENT_MODE=containerapp)
# URL to your deployed agent service container app
CONTAINERAPP_AGENT_URL=https://your-agent-service.azurecontainerapps.io

# Foundry Toolbox MCP
# Set this to the toolbox MCP endpoint URL WITHOUT api-version (automatically appended).
# Example: https://<account>.services.ai.azure.com/api/projects/<project>/toolboxes/<name>/mcp
# Note: The agent code automatically adds ?api-version=v1
TOOLBOX_MCP_URL=

# Knowledge Base (Azure AI Search — semantic search)
# Used for direct KB queries when the toolbox azure_ai_search tool is unavailable.
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_INDEX=foundry-iq-docs-index
AZURE_SEARCH_API_KEY=

# KB setup scripts requirement
# AZURE_RESOURCE_GROUP is the RG containing the search service + storage account.
# Foundry account/project are inferred from FOUNDRY_PROJECT_ENDPOINT.
AZURE_RESOURCE_GROUP=

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# Content Understanding (optional)
# Set this to enable the "+" file attachment button in the UI.
# Files (PDF, images) will be analyzed by Azure Content Understanding.
# Use your Foundry endpoint URL (e.g., https://your-foundry.services.ai.azure.com/)
AZURE_CONTENTUNDERSTANDING_ENDPOINT=
# Optional CU key for key-based auth.
# `/sample-setup` can populate this for you during setup; only set it
# manually if you want to override with your own value.
AZURE_CONTENTUNDERSTANDING_KEY=

# ── Foundry IQ CU Demo ───────────────────────────────────────────────────────
# Set BOTH variables to enable the Foundry IQ Ingestion Mode selector in the UI.
# These point to two separate knowledge bases indexed with different contentExtractionMode:
#   minimal  — standard text extraction (free, tables may misalign)
#   standard — Azure Content Understanding (advanced OCR + table parsing)
# Run scripts/setup-foundry-iq-cu-demo.sh to create them.
FOUNDRY_IQ_MINIMAL_MCP_URL=
FOUNDRY_IQ_STANDARD_MCP_URL=
