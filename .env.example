# ════════════════════════════════════════════════════════════════════════════
# Fibey CU Demo Fork — .env.example
#
# This file has been refactored for the CU demo. The original upstream repo
# (dbarkol/fibey-agent) supports multiple AGENT_MODE values, hosted runtime,
# Container Apps, etc. — almost none of that is needed for the CU demo.
#
# Sections are split into two groups:
#   1) CU demo (required + optional). Demos 1+2 only need the small REQUIRED
#      block. Demo 3 (Foundry IQ KB ingestion) adds the FOUNDRY IQ block.
#   2) Upstream / original repo (all commented out). Uncomment only if you
#      need to run the original hosted-mode demo. The /sample-setup-cu skill
#      will NOT set up any of this.
#
# Recommended way to populate this: run `/sample-setup-cu` and let it write
# the values for you.
# ════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# 1) CU DEMO — REQUIRED for Demos 1 + 2 (CU runtime: prebuilt-layout, custom
#    analyzer + classifier). This is the minimum set to make the agent work.
# ─────────────────────────────────────────────────────────────────────────────

# Foundry project endpoint. Format:
#   https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=

# Chat model deployment name on the Foundry resource (e.g. gpt-4.1-mini).
FOUNDRY_MODEL=gpt-4.1-mini

# Embedding deployment used by CU custom analyzers (for example in local tools).
TEXT_EMBEDDING_3_LARGE_DEPLOYMENT=text-embedding-3-large

# CU data plane endpoint. Format:
#   https://<account>.services.ai.azure.com/
# This can point to the SAME AIServices account as FOUNDRY_PROJECT_ENDPOINT
# (simplest) OR a DIFFERENT one. Use a different account when your Foundry
# account's region doesn't support CU — see CU region availability:
#   https://learn.microsoft.com/en-us/azure/ai-services/content-understanding/language-region-support
# Set this to enable CU file uploads (Demos 1 + 2) and surface the "+"
# attachment button + CU Mode selector in the UI.
AZURE_CONTENTUNDERSTANDING_ENDPOINT=


# ─────────────────────────────────────────────────────────────────────────────
# 2) CU DEMO — OPTIONAL: Demo 3 (Foundry IQ minimal vs standard ingestion)
#    Uncomment + set ALL FOUR variables in this section to enable Demo 3 and
#    show the "KB Extraction Mode" pane in the UI sidebar. The orchestrator
#    will write these for you when you choose `all three` or `3 only`.
# ─────────────────────────────────────────────────────────────────────────────

# RG containing the Storage account + AI Search service for the KB demo.
# Foundry account/project are inferred from FOUNDRY_PROJECT_ENDPOINT.
# AZURE_RESOURCE_GROUP=

# Two Foundry IQ MCP endpoints — one per KB extraction mode.
# Both must be set; setting only one keeps the KB pane hidden.
#   minimal  — standard text extraction (free, tables may misalign)
#   standard — Azure Content Understanding (advanced OCR + table parsing)
# FOUNDRY_IQ_MINIMAL_MCP_URL=
# FOUNDRY_IQ_STANDARD_MCP_URL=

# Direct Search query fallback (used when the Foundry toolbox is unavailable).
# AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
# AZURE_SEARCH_INDEX=foundry-iq-docs-index


# ─────────────────────────────────────────────────────────────────────────────
# 3) CU DEMO — OPTIONAL: gateway tuning. Defaults are fine for local dev.
# ─────────────────────────────────────────────────────────────────────────────

# GATEWAY_HOST=0.0.0.0
# GATEWAY_PORT=8080


# ════════════════════════════════════════════════════════════════════════════
# UPSTREAM / ORIGINAL REPO ONLY (everything below is commented out)
#
# The original Fibey demo supports hosted runtime modes and Foundry Toolbox
# integration. The CU demo fork uses `local-direct` exclusively, with backend
# services run via `./scripts/start-dev.sh` (or `start-dev.ps1`). None of the
# values below are needed for any of the three CU demos.
#
# Uncomment a block ONLY if you specifically want to switch back to the
# upstream demo experience.
# ════════════════════════════════════════════════════════════════════════════

# ─── Agent mode (upstream) ───────────────────────────────────────────────────
# Default is `local-direct` (hardcoded in the gateway) — perfect for the CU
# demo. Override only if you want the upstream behavior.
#   local-direct  — bypass toolbox, call local services directly (default; CU demo uses this)
#   local         — in-process agent + toolbox (upstream local mode)
#   hosted        — proxy to Foundry-hosted agent
#   containerapp  — proxy to self-hosted agent service container app
# AGENT_MODE=local-direct

# ─── local-direct backend services (upstream-shaped, optional override) ──────
# The CU demo doesn't need the inventory / work-orders endpoints to function;
# they're only exercised by the upstream Fibey scenarios.
# INVENTORY_MCP_URL=http://localhost:8001
# WORK_ORDERS_API_URL=http://localhost:8002

# ─── Hosted mode (AGENT_MODE=hosted) ─────────────────────────────────────────
# HOSTED_AGENT_NAME=fibey-agent

# ─── Container App mode (AGENT_MODE=containerapp) ────────────────────────────
# CONTAINERAPP_AGENT_URL=https://your-agent-service.azurecontainerapps.io

# ─── Foundry Toolbox MCP (upstream local / hosted modes) ─────────────────────
# Used by the upstream agent to reach Inventory + Work Orders + Status
# Dashboard via the Foundry Toolbox. The CU demo bypasses this layer.
# Format (no api-version — agent appends ?api-version=v1):
#   https://<account>.services.ai.azure.com/api/projects/<project>/toolboxes/<name>/mcp
# TOOLBOX_MCP_URL=

# ─── Search admin key (upstream) ─────────────────────────────────────────────
# CU demo uses AAD Bearer tokens for Search (no admin key needed).
# Only set this if you're running upstream code paths that haven't migrated.
# AZURE_SEARCH_API_KEY=

# ─── CU key-based auth (rare — Entra is default) ─────────────────────────────
# CU data plane works with AAD (`Cognitive Services User` role). Only set
# this if you have a specific reason to use key auth instead.
# AZURE_CONTENTUNDERSTANDING_KEY=
